---
import type { SeasonIndexEntry } from '../lib/types';
import { seasonUrl } from '../lib/helpers';

interface Props {
  season: SeasonIndexEntry;
  index?: number;
}

const { season, index = 0 } = Astro.props;

const statusLabel = season.infeasible
  ? 'Widerspruch'
  : season.total_solutions === 1
    ? 'Gelöst'
    : `${season.total_solutions.toLocaleString('de-DE')} Lösungen`;

// certainty 0..1 → drives the heat strip width + colour
const certainty = season.infeasible
  ? 0
  : season.total_solutions <= 1
    ? 1
    : Math.max(0.06, 1 / Math.sqrt(season.total_solutions));

const statusColor = season.infeasible
  ? '#ff5d5d'
  : season.total_solutions === 1
    ? '#ffd166'
    : '#c86bff';

const num = String(index + 1).padStart(2, '0');
---

<a
  href={seasonUrl(season.id)}
  class="reveal group relative block bg-[var(--color-ink-2)] p-6 transition-colors duration-300 hover:bg-[var(--color-ink-3)]"
  style={`animation-delay:${0.05 * index + 0.1}s`}
>
  <div class="flex items-start justify-between">
    <span class="font-mono text-[0.7rem] text-[var(--color-bone-mut)] tracking-widest">{num}</span>
    {season.type === 'vip' && (
      <span class="font-mono text-[0.55rem] uppercase tracking-[0.2em] px-1.5 py-0.5 border border-[var(--color-gold)]/60 text-[var(--color-gold)]">VIP</span>
    )}
  </div>

  <h3 class="font-display text-2xl font-bold mt-3 text-[var(--color-bone)] transition-colors group-hover:text-[var(--color-match-hi)]">
    {season.display_name}
  </h3>
  <p class="font-mono text-xs text-[var(--color-bone-mut)] mt-1">
    {season.year} &middot; Ep. {season.latest_episode}/{season.total_episodes} &middot; {season.num_males}m / {season.num_females}w
  </p>

  <!-- heat strip: how close to fully solved -->
  <div class="mt-5 h-1 w-full bg-[var(--color-line)] overflow-hidden">
    <div class="h-full transition-all duration-700"
         style={`width:${Math.round(certainty * 100)}%;background:linear-gradient(90deg,#3a5fb0,${statusColor})`}></div>
  </div>

  <div class="mt-3 flex items-center justify-between">
    <span class="font-mono text-[0.68rem] uppercase tracking-[0.12em]" style={`color:${statusColor}`}>
      {statusLabel}
    </span>
    {season.confirmed_matches > 0 && (
      <span class="font-mono text-[0.68rem] text-[var(--color-bone-mut)]">{season.confirmed_matches} fix</span>
    )}
  </div>
</a>
